{
  "buildCommand": "pnpm run check:landing",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/downloads/chowtrek-latest.apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"chowtrek-latest.apk\""
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
