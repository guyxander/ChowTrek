{
  "expo": {
    "name": "ChowTrek",
    "slug": "chowtrek",
    "scheme": "chowtrek",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/chowtrek-logo.png",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "ng.chowtrek.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/chowtrek-logo.png",
        "backgroundColor": "#003527"
      }
    },
    "plugins": [
      "./plugins/withChowTrekAndroidBuildFixes",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ChowTrek uses your location to show nearby vendors, pickup options, and delivery routes."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#f97316"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ChowTrek uses your photo library so merchants can upload product and storefront images."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "market": "Nigeria",
      "backend": "Supabase",
      "supabaseUrl": "https://uirbiaursigeohaarrua.supabase.co",
      "supabaseAnonKey": "sb_publishable_xKRPJg2qgKSH4nmQVe8Gcg_apafTp9e"
    }
  }
}
